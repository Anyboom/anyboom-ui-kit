{
  "name": "anyboom-ui-kit",
  "type": "module",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "dev": "storybook dev -p 6006 --no-open",
    "build:storybook": "storybook build",
    "preview": "vite preview",
    "lint": "eslint",
    "lint:fix": "eslint --fix",
    "commit": "npx git-cz"
  },
  "dependencies": {
    "vue": "^3.5.39"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^9.1.0",
    "@storybook/addon-docs": "^10.4.6",
    "@storybook/vue3-vite": "^10.4.6",
    "@types/node": "^24.13.2",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "cz-conventional-changelog": "^3.3.0",
    "eslint": "^10.6.0",
    "lint-staged": "^17.0.8",
    "simple-git-hooks": "^2.13.1",
    "storybook": "^10.4.6",
    "typescript": "~6.0.2",
    "vite": "^8.1.1",
    "vue-tsc": "^3.3.5"
  },
  "simple-git-hooks": {
    "pre-commit": "npx lint-staged"
  },
  "lint-staged": {
    "*": "eslint --fix"
  },
  "config": {
    "commitizen": {
      "path": "cz-conventional-changelog"
    }
  }
}
